<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily notes</title>
</head>
<script src="https://cdn.tailwindcss.com"></script>
     <script>
    tailwind.config = {
      theme: {
        screens: {
            'sm': '567px',
            // => @media (min-width: 640px) { ... }

            'md': '768px',
            // => @media (min-width: 768px) { ... }

            'lg': '1024px',
            // => @media (min-width: 1024px) { ... }

            'xl': '1280px',
            // => @media (min-width: 1280px) { ... }

            '2xl': '1536px',
            // => @media (min-width: 1536px) { ... }
          },
        extend: {

          colors: {
            clifford: '#da373d',
          }
        }
      }
    }
  </script>
    <!-- Google Fonts: Great Vibes -->
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet">
    <style>
      .font-great-vibes {
        font-family: 'Great Vibes', cursive;
      }
    </style>
<body>

    <!-- LOGIN PAGE -->

    <section class="max-w-[100%] max-h-[100vh] mx-auto bg-[#ffde59] min-w-[100%] min-h-[100vh]">
        <div class="grid grid-grid-cols-1 lg:grid-cols-2 gap-x-4">
      <!-- col 1 (hidden on screens smaller than `sm`) -->
      <div class="hidden sm:block bg-[url('mynote6.webp')] md:mr-[20%] lg:mr-[3%] bg-no-repeat bg-cover min-h-[100vh]">
        <div class="min-w-[100%] min-h-[100vh] flex justify-center items-center">
          <p class="text-3xl font-serif text-center px-6 md:px-0 md:ml-[40%] lg:mr-[10%]">Every idea matters.<br> Log in now to capture new thoughts or revisit old ones. With NotesApp, you’ll always have a secure and simple space to keep your mind clear and your life organized</p>
        </div>
      </div>

            <!-- col 2 -->
             <div class="bg-[#ffde59]">
                <div class="border-solid border-4 border-black m-[5%] sm:m-[8%] min-h-[80vh] flex flex-col  items-center">
                    <h1 class=" rounded-full text-2xl font-serif px-[30px] py-[10px] my-[20px] bg-[orange]">Login Page</h1>
                    
                    <form action="/login" method="POST" class="flex flex-col  font-serif mt-[20px] gap-y-10">

                      <div>
                        <label for="email" class="text-2xl">Email</label><br>
                        <input type="email" name="username" placeholder="Enter email" class="mt-[10px] py-[10px] sm:min-w-[105%] px-[5px] min-w-[100%]">
                      </div>

                      <div>
                        <label for="password" class="text-2xl">Password</label><br>
                        <input type="password" name="password" placeholder="Enter password" class="mt-[10px] py-[10px] sm:min-w-[105%] px-[5px] min-w-[100%]">
                      </div>

                      <div class="flex gap-x-[15%] text-2xl">
                      <button type="submit" class="bg-[orange] sm:px-[30px] px-[20px] py-[10px] rounded-full ">Login</button>
                      <a href="/register" role="button" class="bg-[orange] sm:px-[30px] px-[15px] py-[10px] mr-[10px] rounded-full">Register</a>
                      </div>
                    </form>

                </div>

             </div>
            

        </div>
    </section>
    
</body>
</html>